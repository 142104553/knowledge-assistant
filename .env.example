# 企业智能知识助手 - 环境变量配置模板
#
# 使用方式：
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的实际配置值
#   3. 应用启动时会自动读取

# ═══════════════════════════════════════════════════════════
# LLM 配置
# ═══════════════════════════════════════════════════════════

# OpenAI 兼容 API Key（必填）
OPENAI_API_KEY=your-api-key-here

# API 基础地址（必须包含 /v1）
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 模型名称
LLM_MODEL=mimo-v2.5

# 生成温度（0=确定性高，1=创造性高）
LLM_TEMPERATURE=0.3

# ═══════════════════════════════════════════════════════════
# Embedding 配置
# ═══════════════════════════════════════════════════════════

# 提供商: local（当前仅支持本地 BGE，Embedding API 未开放）
EMBEDDING_PROVIDER=local

# 模型名称（本地 BGE-small-zh-v1.5，512维，首次自动下载）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 向量维度
EMBEDDING_DIMENSION=512

# HuggingFace 镜像（国内网络环境必填）
HF_ENDPOINT=https://hf-mirror.com

# ═══════════════════════════════════════════════════════════
# 向量数据库配置
# ═══════════════════════════════════════════════════════════

# 提供商: chroma
VECTORSTORE_PROVIDER=chroma

# Collection 名称
VECTORSTORE_COLLECTION=documents

# Chroma 持久化目录
CHROMA_PERSIST_DIR=./chroma_db

# ═══════════════════════════════════════════════════════════
# 元数据数据库
# ═══════════════════════════════════════════════════════════

DATABASE_PATH=./data/app.db

# ═══════════════════════════════════════════════════════════
# RAG 配置
# ═══════════════════════════════════════════════════════════

# 分块大小（字符数）
CHUNK_SIZE=512

# 块间重叠
CHUNK_OVERLAP=50

# 默认检索数量
TOP_K=15

# 相似度阈值（低于此值的结果被过滤）
SCORE_THRESHOLD=0.5

# 最大上下文 Token 数（控制传给 LLM 的上下文长度）
MAX_CONTEXT_TOKENS=8000

# ═══════════════════════════════════════════════════════════
# Agent 配置
# ═══════════════════════════════════════════════════════════

# 是否启用 Agent 模式
ENABLE_AGENT=true

# ═══════════════════════════════════════════════════════════
# 应用配置
# ═══════════════════════════════════════════════════════════

# 调试模式
DEBUG=false
